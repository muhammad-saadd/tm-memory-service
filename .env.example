# Server
PORT=3000
NODE_ENV=development
API_KEY=your-secret-api-key-here

# Database (PostgreSQL) — docker-compose provides DB_HOST/DB_PORT
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=transcripts

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Object Storage (MinIO) — docker-compose provides STORAGE_ENDPOINT
STORAGE_ACCESS_KEY=twinmind
STORAGE_SECRET_KEY=twinmind123
STORAGE_BUCKET=memories

# Processor
PROCESSOR_POLL_INTERVAL_MS=5000
PROCESSOR_MAX_ATTEMPTS=3
